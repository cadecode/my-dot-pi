# ============================================================
# .pi/.gitignore — 分享到 GitHub 的隐私与安全配置
# 
# 用途: 将 .pi 目录分享到 GitHub 作为 pi 配置和 skill 仓库
# 生成依据: oracle + reviewer 双重审计
# ============================================================

# ============================================
# 🔴 密钥/凭证 — 绝对不要提交
# ============================================
agent/auth.json                   # DeepSeek + GLM API 密钥
agent/models.json                 # 含 GLM apiKey（与 auth.json 重复）
web-search.json                   # Exa API Key
skills/brave-search/config.json   # Brave API Key

# ============================================
# 🔴 对话历史与会话数据（隐私敏感）
# ============================================
agent/run-history.jsonl           # agent 调用日志
agent/inspect/                    # 完整对话快照（含系统提示、命令记录）
agent/sessions/                   # 会话历史（含完整对话、token 用量、费用）
agent/pi-cache-optimizer-stats.json  # 含 session ID 和使用模式

# ============================================
# 🔴 二进制文件
# ============================================
agent/bin/                        # 可执行文件
**/*.exe
**/*.dll
**/*.so
**/*.dylib

# ============================================
# 🔴 依赖目录（无用的第三方代码）
# ============================================
node_modules/
**/node_modules/
.venv/
**/.venv/
venv/
**/venv/

# ============================================
# 🔴 Python 缓存与构建产物
# ============================================
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
wheels/
.python-version

# ============================================
# 🔴 临时文件
# ============================================
_temp_*                           # PDF 截图等临时文件
*.log
*.tmp
.cache/
**/.cache/

# ============================================
# 🔴 浏览器配置文件
# ============================================
**/.headless-profile/
**/.edge-browser-tools/

# ============================================
# 🔴 嵌套 .git 目录（子技能仓库）
#     这些技能原本是独立仓库，可考虑:
#     a) 删除 .git 目录纳入根仓库
#     b) 作为 git submodule
# ============================================
agent/skills/pdf/.git/
agent/skills/pptx/.git/
agent/skills/tavily-search/.git/
agent/skills/xlsx/.git/

# ============================================
# 🔴 操作系统文件
# ============================================
.DS_Store
Thumbs.db
Desktop.ini

# ============================================
# 🔴 包管理器锁文件（可选保留或排除）
# ============================================
pnpm-lock.yaml
uv.lock
# package-lock.json   ← 如需保留，取消注释即可

# ============================================
# 🔴 IDE / 编辑器配置
# ============================================
.idea/
.vscode/
*.swp
*.swo
